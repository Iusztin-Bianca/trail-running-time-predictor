{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Debug FastAPI (main.py)",
        "type": "python",
        "request": "launch",
        "module": "uvicorn",
        "args": [
          "app.main:app",
          "--reload"
        ],
        "cwd": "${workspaceFolder}/backend"
      },
      {
        "name": "Attach to Python Functions",
        "type": "debugpy",
        "request": "attach",
        "connect": {
          "host": "localhost",
          "port": 9091
        },
        "preLaunchTask": "func: host start"
      }
    ]
  }
  